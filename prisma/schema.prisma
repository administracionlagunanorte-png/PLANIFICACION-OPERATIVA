generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ============================================================
// USUARIOS Y AUTENTICACIÓN
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("USER")
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Task {
  id            String   @id @default(cuid())
  description   String
  sector        String
  repairType    String
  priority      String
  etapa         String   @default("")
  status        String   @default("Pendiente")
  responsible   String?
  estimatedTime String?
  amount        Float?
  startDate     DateTime?
  endDate       DateTime?
  comments       String?
  approvalStatus String   @default("En espera de decisión")
  beforePhotos   String   @default("[]")
  afterPhotos    String   @default("[]")
  documents      String   @default("[]")
  workOrder      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RepairType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Priority {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  changedBy String?
  createdAt DateTime @default(now())
}

model Material {
  id          String   @id @default(cuid())
  taskId      String
  name        String
  quantity    String?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Status {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Responsible {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Etapa {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// RENDICIÓN DE GASTOS
// ============================================================

model ExpenseReport {
  id                String        @id @default(cuid())
  correlativeNumber Int           @unique
  title             String
  description       String?
  status            String        @default("BORRADOR")
  totalAmount       Float         @default(0)
  responsible       String?
  reviewNote        String?
  reviewedBy        String?
  reviewedAt        DateTime?
  submittedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             ExpenseItem[]

  @@map("expense_reports")
}

model ExpenseItem {
  id             String        @id @default(cuid())
  description    String
  numeroBoleta   String
  montoRendir    Float
  category       String
  expenseDate    DateTime
  imageBoletaUrl String        @default("") @db.Text
  imageCompraUrls String       @default("[]") @db.Text
  reportId       String
  report         ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("expense_items")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("📦")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expense_categories")
}

// ============================================================
// SOLICITUDES DE COMPRA
// ============================================================

model PurchaseRequest {
  id                 String            @id @default(cuid())
  correlativeNumber  Int               @unique
  title              String            @default("")
  productDescription String            @default("")
  brand              String?
  quantity           Int               @default(1)
  priority           String            @default("MEDIA")
  productLink        String?           @db.Text
  referencePhotoUrl  String?           @db.Text
  directProvider     String?
  notes              String?
  status             String            @default("PENDIENTE")
  responsible        String?
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNote         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  quotes             PurchaseQuote[]
  items              PurchaseItem[]

  @@map("purchase_requests")
}

model PurchaseItem {
  id                String           @id @default(cuid())
  productDescription String
  brand             String?
  quantity          Int              @default(1)
  productLink       String?          @db.Text
  referencePhotoUrl String?          @db.Text
  directProvider    String?
  notes             String?
  requestId         String
  request           PurchaseRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("purchase_items")
}

model PurchaseQuote {
  id                String           @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest  @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  providerName      String
  amount            Float
  currency          String           @default("CLP")
  fileName          String?
  fileUrl           String?          @db.Text
  fileType          String?
  notes             String?
  isWinner          Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("purchase_quotes")
}

// ============================================================
// ANTICIPOS
// ============================================================

model AnticipoPeriod {
  id          String    @id @default(cuid())
  name        String                // Ej: "Junio 2026"
  month       Int                   // 1-12
  year        Int
  status      String    @default("ABIERTO")  // ABIERTO, CERRADO
  totalAmount Float      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  anticipos   Anticipo[]

  @@map("anticipo_periods")
}

model Anticipo {
  id            String        @id @default(cuid())
  numero        Int                          // N° correlativo dentro del periodo
  nombre        String                       // Nombre completo
  rut           String                       // RUT
  monto         Float                         // Monto del anticipo
  cuentaBancaria String      @default("")    // Cuenta bancaria
  periodoId     String
  periodo       AnticipoPeriod @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  status        String        @default("PENDIENTE")  // PENDIENTE, PAGADO, RECHAZADO
  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("anticipos")
}

model Worker {
  id              String   @id @default(cuid())
  nombre          String              // Nombre completo
  rut             String              // RUT
  cuentaBancaria  String   @default("")  // Cuenta bancaria
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  asistencias     AsistenciaRecord[]

  @@map("workers")
}

model AnticipoAlertConfig {
  id          String   @id @default(cuid())
  dayOfMonth  Int      @default(13)   // Día del mes para la alerta (1-31)
  active      Boolean  @default(true) // Si la alerta está activa
  message     String   @default("Plazo vencido: Anticipos pendientes deben ser pagados") // Mensaje de la alerta
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("anticipo_alert_config")
}

// ============================================================
// MANTENIMIENTO
// ============================================================

model MantenimientoLV {
  id              String   @id @default(cuid())
  codigo          String              // LV-01, LV-02, etc.
  nombre          String              // Nombre de la lista de verificación
  sector          String              // Sector
  frecuencia      String              // Diaria, 3x Semanal, Semanal, Quincenal, Mensual, Trimestral, Semestral, Anual
  status          String   @default("PENDIENTE")  // PENDIENTE, EN_PROGRESO, COMPLETADA
  progress        Int      @default(0)  // 0-100 percentage
  scheduledDate   DateTime?           // Fecha programada
  completedDate   DateTime?           // Fecha completada
  responsable     String?             // Responsable
  turno           String?             // Turno
  observations    String?             // Observaciones generales
  motivoPendiente String?             // Motivo por el que no se realizó (si está pendiente)
  attachments     String   @default("[]") @db.Text  // JSON array of file URLs
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items           MantenimientoItem[]

  @@map("mantenimiento_lv")
}

model MantenimientoItem {
  id          String         @id @default(cuid())
  lvId        String
  lv          MantenimientoLV @relation(fields: [lvId], references: [id], onDelete: Cascade)
  category    String         // A, B, C, D sub-section
  description String         // Task description
  status      String  @default("PENDIENTE")  // PENDIENTE, OK, NO_OK, N/A
  value       String?        // For measurements (pH, temp, etc.)
  observation String?
  order       Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("mantenimiento_items")
}

// ============================================================
// ASISTENCIAS
// ============================================================

model AsistenciaRecord {
  id            String   @id @default(cuid())
  workerId      String                      // FK a Worker
  worker        Worker    @relation(fields: [workerId], references: [id])
  date          DateTime                    // Fecha de la ausencia/atraso
  type          String                      // "AUSENCIA" o "ATRASO"
  minutesLate   Int       @default(0)       // Minutos de atraso (solo si type=ATRASO)
  reason        String?                     // Motivo u observación
  reportedBy    String?                     // Quien reportó (supervisor)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("asistencia_records")
}

model AsistenciaAlertConfig {
  id          String   @id @default(cuid())
  dayOfMonth  Int      @default(29)   // Día del mes para la alerta/informe (1-31)
  active      Boolean  @default(true) // Si la alerta está activa
  message     String   @default("Informe mensual de asistencias: Revisar y enviar listado de atrasos e inasistencias")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("asistencia_alert_config")
}

// ============================================================
// SISTEMA DE ALERTAS UNIFICADO
// ============================================================

model ModuleAlert {
  id          String   @id @default(cuid())
  module      String                 // "mantenimiento", "rendicion", "compras", "anticipos", "asistencias"
  alertType   String                 // Tipo de alerta: "vencimiento", "informe", "recordatorio", "urgente"
  title       String                 // Título breve de la alerta
  message     String                 // Mensaje detallado
  dayOfMonth  Int       @default(1)  // Día del mes para activarse (1-31)
  active      Boolean   @default(true)
  auto        Boolean   @default(true)  // true = automática según fecha, false = manual (la activa el admin)
  targetRole  String    @default("ALL") // "ALL", "ADMIN", "SUPERVISOR", "USER"
  priority    String    @default("warning") // "info", "warning", "urgent", "critical"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("module_alerts")
}
