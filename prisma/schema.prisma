generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Task {
  id            String   @id @default(cuid())
  description   String
  sector        String
  repairType    String
  priority      String
  etapa         String   @default("")
  status        String   @default("Pendiente")
  responsible   String?
  estimatedTime String?
  amount        Float?
  startDate     DateTime?
  endDate       DateTime?
  comments       String?
  approvalStatus String   @default("En espera de decisión")
  beforePhotos   String   @default("[]")
  afterPhotos    String   @default("[]")
  documents      String   @default("[]")
  workOrder      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RepairType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Priority {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  changedBy String?
  createdAt DateTime @default(now())
}

model Material {
  id          String   @id @default(cuid())
  taskId      String
  name        String
  quantity    String?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Status {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Responsible {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Etapa {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// RENDICIÓN DE GASTOS
// ============================================================

model ExpenseReport {
  id                String        @id @default(cuid())
  correlativeNumber Int           @unique
  title             String
  description       String?
  status            String        @default("BORRADOR")
  totalAmount       Float         @default(0)
  responsible       String?
  reviewNote        String?
  reviewedBy        String?
  reviewedAt        DateTime?
  submittedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             ExpenseItem[]

  @@map("expense_reports")
}

model ExpenseItem {
  id             String        @id @default(cuid())
  description    String
  numeroBoleta   String
  montoRendir    Float
  category       String
  expenseDate    DateTime
  imageBoletaUrl String        @default("") @db.Text
  imageCompraUrl String        @default("") @db.Text
  reportId       String
  report         ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("expense_items")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("📦")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expense_categories")
}

// ============================================================
// SOLICITUDES DE COMPRA
// ============================================================

model PurchaseRequest {
  id                 String            @id @default(cuid())
  correlativeNumber  Int               @unique
  productDescription String
  brand              String?
  quantity           Int               @default(1)
  priority           String            @default("MEDIA")
  productLink        String?           @db.Text
  referencePhotoUrl  String?           @db.Text
  directProvider     String?
  notes              String?
  status             String            @default("PENDIENTE")
  responsible        String?
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNote         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  quotes             PurchaseQuote[]

  @@map("purchase_requests")
}

model PurchaseQuote {
  id                String           @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest  @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  providerName      String
  amount            Float
  currency          String           @default("CLP")
  fileName          String?
  fileUrl           String?          @db.Text
  fileType          String?
  notes             String?
  isWinner          Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("purchase_quotes")
}
