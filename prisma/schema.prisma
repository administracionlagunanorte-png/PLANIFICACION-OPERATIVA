generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Task {
  id            String   @id @default(cuid())
  description   String
  sector        String
  repairType    String
  priority      String
  etapa         String   @default("")
  status        String   @default("Pendiente")
  responsible   String?
  estimatedTime String?
  amount        Float?
  startDate     DateTime?
  endDate       DateTime?
  comments      String?
  beforePhotos  String   @default("[]")
  afterPhotos   String   @default("[]")
  documents     String   @default("[]")
  workOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RepairType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Priority {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  action    String   // "creada", "actualizada", "eliminada", "cambio_estado"
  field     String?  // which field changed
  oldValue  String?  // previous value
  newValue  String?  // new value
  changedBy String?  // who made the change
  createdAt DateTime @default(now())
}

model Material {
  id          String   @id @default(cuid())
  taskId      String
  name        String   // nombre del material
  quantity    String?  // cantidad
  unit        String?  // unidad (unidades, kg, m2, m, lt, etc.)
  unitPrice   Float?   // precio unitario
  totalPrice  Float?   // precio total
  category    String?  // categoría (herrajes, eléctrico, plomería, etc.)
  notes       String?  // notas/observaciones
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Status {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Responsible {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Etapa {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
