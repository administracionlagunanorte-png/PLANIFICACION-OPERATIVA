generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Task {
  id            String   @id @default(cuid())
  description   String
  sector        String
  repairType    String
  priority      String
  etapa         String   @default("")
  status        String   @default("Pendiente")
  responsible   String?
  estimatedTime String?
  amount        Float?
  startDate     DateTime?
  endDate       DateTime?
  comments       String?
  approvalStatus String   @default("En espera de decisión")
  beforePhotos   String   @default("[]")
  afterPhotos    String   @default("[]")
  documents      String   @default("[]")
  workOrder      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RepairType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Priority {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  action    String   // "creada", "actualizada", "eliminada", "cambio_estado"
  field     String?  // which field changed
  oldValue  String?  // previous value
  newValue  String?  // new value
  changedBy String?  // who made the change
  createdAt DateTime @default(now())
}

model Material {
  id          String   @id @default(cuid())
  taskId      String
  name        String   // nombre del material
  quantity    String?  // cantidad
  unit        String?  // unidad (unidades, kg, m2, m, lt, etc.)
  unitPrice   Float?   // precio unitario
  totalPrice  Float?   // precio total
  category    String?  // categoría (herrajes, eléctrico, plomería, etc.)
  notes       String?  // notas/observaciones
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Status {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Responsible {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Etapa {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseReport {
  id              String   @id @default(cuid())
  numero          Int      @default(0)           // número correlativo de rendición
  taskId          String?                        // vinculado a una tarea (opcional)
  description     String                         // descripción del gasto
  category        String                         // categoría (materiales, mano de obra, transporte, servicios, otros)
  amount          Float                          // monto del gasto
  date            DateTime                       // fecha del gasto
  responsible     String?                        // responsable del gasto
  supplier        String?                        // proveedor
  receiptNumber   String?                        // número de boleta/factura
  receiptType     String?                        // tipo de documento (boleta, factura, recibo, otro)
  receiptPhoto    String   @default("[]")        // fotos del comprobante (JSON array de URLs)
  notes           String?                        // observaciones
  approvalStatus  String   @default("En espera de decisión")  // Aprobado / No aprobado / En espera
  approvedBy      String?                        // quien aprobó
  approvedAt      DateTime?                      // fecha de aprobación
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
